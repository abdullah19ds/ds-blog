{.section item}
<article class="post-single" data-content-field="main-content">

  <!-- Post header -->
  <header class="post-header">
    <div class="container container-narrow">
      <p class="post-breadcrumb">
        <a href="{collection.fullUrl}">← {collection.title}</a>
      </p>
      <p class="post-meta">
        <time datetime="{addedOn|date %Y-%m-%d}">{addedOn|date %B %d, %Y}</time>
        {.section author.displayName}
          <span aria-hidden="true">·</span>
          <span>By {author.displayName}</span>
        {.end}
      </p>
      <h1>{title}</h1>
      {.section categories}
        <div class="post-tags" role="list">
          {.repeated section @}<span class="post-tag" role="listitem">{@}</span>{.end}
        </div>
      {.end}
    </div>
  </header>

  <!-- Cover image -->
  {.section assetUrl}
    <figure class="post-cover">
      <div class="container">
        <img src="{assetUrl}?format=2000w" alt="{title}" loading="eager">
      </div>
    </figure>
  {.end}

  <!-- Body + sidebar -->
  <div class="container">
    <div class="post-body-wrap">
      <!-- Main prose -->
      <div class="prose">
        {body|safe}
      </div>

      <!-- Sidebar CTA (sticky) -->
      <aside class="post-sidebar" aria-label="Studio CTA">
        <p class="post-sidebar-label">From the studio</p>
        <div class="post-sidebar-cta">
          <h4>Want this kind of thinking for your brand?</h4>
          <p>We help design-led teams ship work that actually performs.</p>
          <a class="btn btn-primary btn-sm" href="/pricing">See pricing</a>
        </div>
      </aside>
    </div>

    <!-- Post footer -->
    <footer class="post-footer">
      {.section sourceUrl}
        <a href="{sourceUrl}" target="_blank" rel="noopener noreferrer">View source →</a>
      {.end}
      <div>{@|apply sqs-share-buttons}</div>
    </footer>
  </div>

</article>

<!-- Post CTA strip -->
<section class="post-cta-strip">
  <div class="container container-narrow">
    <div class="cta-card">
      <div>
        <p class="eyebrow eyebrow-accent">Work with us</p>
        <h2>Want this clarity for your brand?</h2>
        <p>Tell us the deadline and the metric. We reply the same day.</p>
        <div class="cta-actions">
          <a class="btn btn-primary" href="/pricing">See pricing</a>
          <a class="btn btn-outline" href="{collection.fullUrl}">More articles</a>
        </div>
      </div>
    </div>
  </div>
</section>
{.end}
