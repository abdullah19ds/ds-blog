{.section item}
<article class="post" data-content-field="main-content">

  <header class="post-header">
    <div class="container container-narrow">
      <p class="post-breadcrumb"><a href="{collection.fullUrl}">&larr; {collection.title}</a></p>
      <p class="post-meta">
        <time datetime="{addedOn|date %Y-%m-%d}">{addedOn|date %B %d, %Y}</time>
        {.section author.displayName}
          <span class="post-meta-sep" aria-hidden="true">&middot;</span>
          <span>By {author.displayName}</span>
        {.end}
      </p>
      <h1 class="post-title">{title}</h1>
      {.section categories}
        <p class="post-tags">
          {.repeated section @}<span class="post-tag">{@}</span>{.end}
        </p>
      {.end}
    </div>
  </header>

  {.section assetUrl}
    <figure class="post-cover">
      <img src="{assetUrl}?format=2000w" alt="{title}">
    </figure>
  {.end}

  <div class="container container-narrow">
    <div class="post-body">
      {body|safe}
    </div>

    <footer class="post-footer">
      {.section sourceUrl}
        <p class="post-source"><a href="{sourceUrl}" target="_blank" rel="noopener">View original source &rarr;</a></p>
      {.end}
      <div class="post-share">
        {@|apply sqs-share-buttons}
      </div>
    </footer>
  </div>

</article>

<section class="post-cta">
  <div class="container container-narrow">
    <h2>Want this kind of clarity for your brand?</h2>
    <p>We help design-led teams ship work that actually performs. Let's talk.</p>
    <a href="/pricing" class="btn btn-primary">See pricing</a>
  </div>
</section>
{.end}
