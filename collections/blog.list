<section class="blog-hero">
  <div class="container">
    <p class="eyebrow">{collection.title}</p>
    <h1>Notes on craft, strategy, and shipping</h1>
    <p class="lead">Field reports from the studio — what's working, what isn't, and what we're paying attention to next.</p>
  </div>
</section>

<section class="blog-list-section">
  <div class="container">

    {.section pagination}
      {.section items}
        <ul class="post-grid">
          {.repeated section @}
            <li class="post-card">
              <a href="{fullUrl}" class="post-card-link">
                {.section assetUrl}
                  <div class="post-card-media">
                    <img src="{assetUrl}?format=1000w" alt="{title}" loading="lazy">
                  </div>
                {.end}
                <div class="post-card-body">
                  <p class="post-meta">
                    <time datetime="{addedOn|date %Y-%m-%d}">{addedOn|date %B %d, %Y}</time>
                    {.section categories}
                      {.repeated section @}<span class="post-tag">{@}</span>{.end}
                    {.end}
                  </p>
                  <h2 class="post-card-title">{title}</h2>
                  {.section excerpt}
                    <div class="post-card-excerpt">{excerpt|safe}</div>
                  {.end}
                  <span class="post-card-cta">Read article <span aria-hidden="true">&rarr;</span></span>
                </div>
              </a>
            </li>
          {.end}
        </ul>

        <nav class="pagination" aria-label="Blog pagination">
          {.section prevPage}
            <a class="pagination-link" href="{fullUrl}" rel="prev">&larr; Newer</a>
          {.or}
            <span class="pagination-link is-disabled">&larr; Newer</span>
          {.end}
          {.section nextPage}
            <a class="pagination-link" href="{fullUrl}" rel="next">Older &rarr;</a>
          {.or}
            <span class="pagination-link is-disabled">Older &rarr;</span>
          {.end}
        </nav>
      {.or}
        <div class="empty-state">
          <h2>No posts yet</h2>
          <p>The first article is on its way. Check back soon.</p>
        </div>
      {.end}
    {.end}

  </div>
</section>
