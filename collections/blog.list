<!-- Blog Hero -->
<section class="blog-hero">
  <div class="container">
    <div class="tag">Our Blog</div>
    <h1>Design Insights & <span>Creative Stories</span></h1>
    <p>Expert perspectives on branding, UI/UX, design trends, and building remarkable digital products.</p>

    <div class="blog-categories">
      <button class="cat-btn active">All Posts</button>
      <button class="cat-btn">Branding</button>
      <button class="cat-btn">UI/UX</button>
      <button class="cat-btn">Web Design</button>
      <button class="cat-btn">Motion</button>
      <button class="cat-btn">Strategy</button>
    </div>
  </div>
</section>

{.section collection}

  {.section items}

    <!-- Featured Post (first item) -->
    {.section 0}
    <section class="blog-featured">
      <div class="container">
        <a href="{fullUrl}" class="featured-post">
          <div class="fp-image">
            {.section assetUrl}
              <img src="{assetUrl}" alt="{title}">
            {.end}
            {.section assetUrl|not}
              <div class="fp-image-placeholder">✦</div>
            {.end}
          </div>
          <div class="fp-content">
            <div class="fp-meta">
              <span class="fp-cat">{.section categories}{.repeated section @}<span>{@}</span>{.alternates with}, {.end}{.end}</span>
              <span class="fp-read-time">5 min read</span>
            </div>
            <h2>{title}</h2>
            <p>{excerpt}</p>
            <div class="fp-author">
              <div class="author-av">{author.displayName|slice 0,2|upper}</div>
              <div class="author-info">
                <div class="name">{author.displayName}</div>
                <div class="date">{addedOn|date %B %d, %Y}</div>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
    {.end}

  {.end}

  <!-- Posts Grid (items 1+) -->
  <section class="blog-posts">
    <div class="container">
      <div class="posts-grid">
        {.repeated section items}
          {.section index|ne 0}
          <article class="post-card">
            <a href="{fullUrl}">
              <div class="post-image">
                {.section assetUrl}
                  <img src="{assetUrl}" alt="{title}">
                {.end}
                {.section assetUrl|not}
                  <div class="post-img-placeholder">✦</div>
                {.end}
              </div>
            </a>
            <div class="post-content">
              <div class="post-meta">
                <span class="post-cat">{.section categories}{.section 0}{@}{.end}{.end}</span>
                <span class="dot-sep">·</span>
                <span class="post-date">{addedOn|date %b %d, %Y}</span>
              </div>
              <h3><a href="{fullUrl}">{title}</a></h3>
              <p>{excerpt}</p>
              <a href="{fullUrl}" class="read-more">Read Article</a>
            </div>
          </article>
          {.end}
        {.end}
      </div>

      <!-- Pagination -->
      <nav class="pagination">
        {.section pagination}
          {.section prevPage}
            <a href="{prevPageUrl}">&larr;</a>
          {.end}

          {.repeated section pageLinks}
            {.section active}
              <a href="{url}" class="current">{pageNum}</a>
            {.end}
            {.section active|not}
              <a href="{url}">{pageNum}</a>
            {.end}
          {.end}

          {.section nextPage}
            <a href="{nextPageUrl}">&rarr;</a>
          {.end}
        {.end}
      </nav>
    </div>
  </section>

{.end}
