<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{website.siteTitle}</title>
  <meta name="description" content="{website.siteDescription}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

  <squarespace:script src="site.js" combo="true" />
</head>
<body class="{squarespace.page-classes}" id="{squarespace.page-id}">

  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header" data-sqsp-section="header">
    <div class="container site-header-inner">
      <a class="brand" href="/" aria-label="{website.siteTitle} home">
        <span class="brand-mark" aria-hidden="true">DS</span>
        <span class="brand-name">{website.siteTitle}</span>
      </a>
      <button class="nav-toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
      <div id="primary-nav" class="primary-nav">
        <squarespace:navigation navigationId="mainNav" template="navigation" />
        <a class="btn btn-primary nav-cta" href="/pricing">Start a project</a>
      </div>
    </div>
  </header>

  <main id="main" role="main" data-content-field="main-content">
    {squarespace.main-content}
  </main>

  <footer class="site-footer" data-sqsp-section="footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <span class="brand-mark" aria-hidden="true">DS</span>
        <p class="footer-tagline">Design that ships. Strategy that compounds.</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <squarespace:navigation navigationId="footerNav" template="navigation" />
      </nav>
      <div class="footer-meta">
        <squarespace:block-field id="footerBlocks" columns="12" label="Footer Content" />
      </div>
    </div>
    <div class="container footer-bottom">
      <p>&copy; {website.siteTitle}. All rights reserved.</p>
      <p class="muted">Built with care, shipped on Squarespace.</p>
    </div>
  </footer>

</body>
</html>
